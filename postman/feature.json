    {
      "name": "Несуществующее событие",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/events/999/rating"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const eventId = pm.request.url.path[1];",
              "const res = pm.response.json();",
              "pm.test(\"Статус 400\", () => pm.response.to.have.status(400));",
              "pm.test(`Событие с id = ${eventId} не существует`, () => {",
              "  pm.expect(res.message).to.include(\"Event not found\");",
              "});",
              "console.log(`Попытка получить рейтинг несуществующего события id = ${eventId}: ${res.message}`);"
            ]
          }
        }

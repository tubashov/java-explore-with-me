{
  "info": {
    "name": "Explore With Me - Rating Events Feature",
    "_postman_id": "e9a2f8b0-5678-4abc-8def-987654321000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Single User Rating Update (like → dislike → like)",
      "item": [
        {
          "name": "Пользователь 1 ставит лайк",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/events/1/rating?userId=1&liked=true"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const eventId = pm.request.url.path[1];",
                  "const res = pm.response.json();",
                  "console.log(`Шаг 1: Пользователь 1 ставит лайк → eventId = ${eventId}, liked = ${res.liked}`);",
                  "pm.test(\"Статус 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Ответ содержит eventId, userId, liked\", () => {",
                  "  pm.expect(res).to.have.property('eventId');",
                  "  pm.expect(res).to.have.property('userId');",
                  "  pm.expect(res).to.have.property('liked');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Пользователь 1 ставит дизлайк",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/events/1/rating?userId=1&liked=false"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const eventId = pm.request.url.path[1];",
                  "const res = pm.response.json();",
                  "console.log(`Шаг 2: Пользователь 1 ставит дизлайк → eventId = ${eventId}, liked = ${res.liked}`);",
                  "pm.test(\"Статус 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Ответ содержит eventId, userId, liked\", () => {",
                  "  pm.expect(res).to.have.property('eventId');",
                  "  pm.expect(res).to.have.property('userId');",
                  "  pm.expect(res).to.have.property('liked');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Пользователь 1 снова ставит лайк",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/events/1/rating?userId=1&liked=true"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const eventId = pm.request.url.path[1];",
                  "const res = pm.response.json();",
                  "console.log(`Шаг 3: Пользователь 1 снова ставит лайк → eventId = ${eventId}, liked = ${res.liked}`);",
                  "pm.test(\"Статус 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Ответ содержит eventId, userId, liked\", () => {",
                  "  pm.expect(res).to.have.property('eventId');",
                  "  pm.expect(res).to.have.property('userId');",
                  "  pm.expect(res).to.have.property('liked');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Итоговый рейтинг после одного пользователя",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events/1/rating"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const eventId = pm.request.url.path[1];",
                  "const res = pm.response.json();",
                  "console.log(`Итоговый рейтинг после одного пользователя → eventId = ${eventId}, likes = ${res.likes}, dislikes = ${res.dislikes}`);",
                  "pm.test(\"Статус 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Ответ содержит likes и dislikes\", () => {",
                  "  pm.expect(res).to.have.property('likes');",
                  "  pm.expect(res).to.have.property('dislikes');",
                  "});",
                  "pm.test(`Итоговый рейтинг события id = ${eventId} корректен`, () => {",
                  "  pm.expect(res.likes).to.be.at.least(0);",
                  "  pm.expect(res.dislikes).to.be.at.least(0);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

